# ACORN All-in-One Container
# Single container running postgres, redis, ollama, api, relay, ui via supervisord
# Usage: docker run -p 8501:8501 -p 8000:8000 -p 9000:9000 ghcr.io/sharathsphd/acorn-aio:latest
FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y \
    curl wget git python3 python3-pip python3-venv \
    postgresql postgresql-contrib \
    redis-server \
    supervisor \
    jq \
    && rm -rf /var/lib/apt/lists/*

RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y nodejs

RUN curl -fsSL https://ollama.com/install.sh | sh

RUN apt-get update && apt-get install -y postgresql-16-pgvector 2>/dev/null \
    || echo "pgvector will be installed from source if needed" \
    && rm -rf /var/lib/apt/lists/*

RUN pip3 install --no-cache-dir \
    fastapi uvicorn[standard] httpx redis sqlalchemy[asyncio] asyncpg \
    pydantic pydantic-settings pgvector \
    pandas numpy scikit-learn plotly \
    requests

RUN npm install -g @anthropic-ai/claude-code

COPY api/ /opt/acorn/api/
COPY memory/ /opt/acorn/memory/
COPY acorn_mcp/acorn-api-relay/ /opt/acorn/relay/
COPY ui-next/ /opt/acorn/ui/
COPY scripts/ /opt/acorn/scripts/
COPY docker/acorn-harness/scripts/ /opt/acorn/harness-scripts/

RUN mkdir -p /var/log/supervisor /var/run/supervisor
COPY docker/supervisord.conf /etc/supervisor/conf.d/acorn.conf

COPY docker/aio-entrypoint.sh /opt/acorn/entrypoint.sh
RUN chmod +x /opt/acorn/entrypoint.sh

VOLUME ["/var/lib/postgresql/data", "/var/lib/redis", "/root/.ollama", "/workspace"]

EXPOSE 8000 8501 9000

ENTRYPOINT ["/opt/acorn/entrypoint.sh"]
