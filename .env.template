## ACORN Environment Template
## Copy to .env and fill in values. Never commit .env.

ACORN_MODE=dgx                          # dgx | mini | cloud

# ── Ollama + Claude Code canonical recipe ───────────────────────────────────
# These three variables tell Claude Code to route through the ACORN relay.
ANTHROPIC_BASE_URL=http://acorn-api-relay:9000
ANTHROPIC_AUTH_TOKEN=ollama
ANTHROPIC_API_KEY=                    # Intentionally empty; proxy manages escalation

# ── Optional Claude API escalation ──────────────────────────────────────────
# Set ANTHROPIC_API_KEY_REAL to enable proxy escalation. Leave empty for fully local.
ANTHROPIC_API_KEY_REAL=

# ── Agent teams ──────────────────────────────────────────────────────────────
CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1

# ── Database and cache ───────────────────────────────────────────────────────
DATABASE_URL=postgresql://acorn:acorn@acorn-postgres:5432/acorn
REDIS_URL=redis://acorn-redis:6379

# ── Inference routing ────────────────────────────────────────────────────────
ROUTING_STRATEGY=passthrough          # passthrough | stall | confidence
STALL_DETECTION_ENABLED=false         # Opt-in only; review telemetry before enabling
LOCAL_CONFIDENCE_THRESHOLD=0.8

# ── Model selection ──────────────────────────────────────────────────────────
DEFAULT_MODEL=llama3.3:70b
CODER_MODEL=qwen3-coder
ANALYSIS_MODEL=glm-4.7

# ── Resource caps ────────────────────────────────────────────────────────────
MAX_AGENTS_PER_PROBLEM=10
MAX_CONCURRENT_PROBLEMS=3
MAX_HARNESS_CONTAINERS=20

# ── Memory and skill library ─────────────────────────────────────────────────
ACORN_SESSION_TTL_HOURS=24
ACORN_MEMORY_TTL_DAYS=90
ACORN_KERNEL_PROMO_THRESHOLD=2
KERNEL_PROBATIONARY_PATH=/workspace/kernels/probationary
KERNEL_PERMANENT_PATH=/workspace/kernels/permanent

# ── Agent behaviour ──────────────────────────────────────────────────────────
ACORN_IDLE_TIMEOUT_SECONDS=120

# ── Feature flags ────────────────────────────────────────────────────────────
TELEMETRY_ENABLED=true
SKILL_EXTRACTION_ENABLED=true
JUDGE_REQUIRED=true                   # NEVER set false in production
META_AGENT_ENABLED=false              # v1.1+
UI_EVOLUTION_ENABLED=false            # v1.1+
CONCURRENT_PROBLEMS_ENABLED=false     # Phase 5+

# ── Observability ────────────────────────────────────────────────────────────
STALL_ESCALATION_ALERT_THRESHOLD=0.3
UI_CHURN_RATE_LIMIT=3
UI_MAX_PAGES=20

# ── Problem (set per-run by new-problem.sh) ──────────────────────────────────
PROBLEM_UUID=

# ── External services (optional — only for non-ACORN tooling) ───────────────
# HF_TOKEN=
# WANDB_API_KEY=
# GITHUB_TOKEN=
